generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CHEFE
  COORDENADOR
  COLABORADOR
}

enum VehicleStatus {
  IN_STOCK
  SOLD
  CANCELED
}

enum MovementType {
  CHECK_IN
  CHECK_OUT
}

enum CheckStatus {
  PENDING
  CLEARED
  RETURNED
}

enum AuditAction {
  CREATE_VEHICLE
  SELL_VEHICLE
  UPDATE_VEHICLE
  CREATE_CHECK
  UPDATE_CHECK_STATUS
  UPLOAD_DOCUMENT
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  movements VehicleMovement[]
  auditLogs AuditLog[]
}

model Vehicle {
  id            String   @id @default(uuid())
  plate         String   @unique
  model         String
  year          Int
  purchaseValue Float
  saleValue     Float?
  status        VehicleStatus @default(IN_STOCK)
  createdAt     DateTime @default(now())

  documents Document[]
  checks    Check[]
  movements VehicleMovement[]
}

model VehicleMovement {
  id        String       @id @default(uuid())
  type      MovementType
  createdAt DateTime     @default(now())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  vehicleId String

  user      User?   @relation(fields: [userId], references: [id])
  userId    String?
}

model Document {
  id           String   @id @default(uuid())
  url          String
  pathname     String
  originalName String
  mimeType     String
  size         Int
  uploadedAt   DateTime @default(now())

  vehicleId    String?
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Check {
  id            String      @id @default(uuid())
  value         Float
  issueDate     DateTime
  expectedClear DateTime
  status        CheckStatus @default(PENDING)
  observation   String?
  createdAt     DateTime    @default(now())

  vehicle       Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId     String?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
}